generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Signal {
  id                     String   @id @default(cuid())
  asset                  String
  timeframe              String
  direction              String   // HIGHER, LOWER, NO_OPERAR
  entryPrice             Float
  entryTime              DateTime
  expirationMinutes      Int
  expirationTime         DateTime
  confidence             Float    // 0-100
  aiReason               String?
  technicalJson          String?  // JSON: technical indicators at entry
  patternsJson           String?  // JSON: detected patterns
  volumeJson             String?  // JSON: volume analysis
  newsJson               String?  // JSON: news data
  sentimentJson          String?  // JSON: sentiment analysis
  macroJson              String?  // JSON: macro events
  fullAnalysisJson       String?  // JSON: combined analysis
  exitPrice              Float?
  result                 String?  // WIN, LOSS, DRAW, NO_OPERAR
  priceDifference        Float?
  estimatedProfit        Float?
  estimatedLoss          Float?
  status                 String   @default("PENDING") // PENDING, CLOSED, CANCELLED
  analysisMode           String   @default("FALLBACK") // FULL, PARTIAL, FALLBACK, DEMO
  dataAvailability       String?  // JSON: what data sources were available
  statisticalReliability String? // LOW, MEDIUM, HIGH, INSUFFICIENT, MANUAL
  historicalSampleSize   Int?
  screenshotUrl          String?
  // === NEW FIELDS FOR STATISTICAL ENGINE ===
  patternType            String?  // breakout, liquidity_sweep, engulfing, fakeout, reversal, trend_continuation, momentum_shift
  sessionType            String?  // Asia, London, New York, Overlap
  setupScore             Float?   // 0-100: calculated from historical pattern+session performance
  indicatorsJson         String?  // JSON: all computed indicators at signal time
  source                 String   @default("MANUAL") // MANUAL, AUTO, AI
  noOperarReason         String?  // Why NO_OPERAR was chosen
  verificationMethod     String?  // SIMULATED, REAL
  // === REGIME & FEATURES (Phase 4) ===
  marketRegime           String?  // TRENDING, RANGING, VOLATILE, LOW_VOL, NEWS, LIQUIDITY_TRAP
  featuresJson           String?  // JSON: 20+ computed features at signal time
  // === EXPECTANCY (Phase 4) ===
  expectancy             Float?   // Expected value (EV) per unit risk
  riskReward             Float?   // Risk/reward ratio at signal time
  adjustedWinRate        Float?   // Bayesian adjusted win rate
  // === BAYESIAN STATS (Phase 4) ===
  confidenceInterval     String?  // JSON: {lower, upper} - 95% CI for this setup
  pValue                 Float?   // P-value for this setup's edge
  sampleVariance         Float?   // Variance of results for this setup
  // === QUALITY (Phase 4) ===
  qualityScore           Float?   // 0-100: quality filter composite score
  qualityFlags           String?  // JSON: array of quality flags (low_liquidity, high_spread, etc.)
  // === MULTI-TIMEFRAME (Phase 5) ===
  mtfConfluence          Float?   // 0-100: MTF confluence score
  mtfDirection           String?  // BULLISH, BEARISH, NEUTRAL
  h1Filter               String?  // PASS, FAIL, NO_DATA
  h4Filter               String?  // PASS, FAIL, NO_DATA
  entryQuality           String?  // EXCELLENT, GOOD, FAIR, POOR, DANGEROUS
  mtfJson                String?  // JSON: full MTF analysis details
  // === PROVEN EDGE (Phase 7) ===
  provenEdgeTier         String?  // TIER_1, TIER_2, TIER_3, or null
  provenEdgeAllowed      Boolean? // Whether this combo is in the proven edges allowlist
  edgeClassification     String?  // GREEN, YELLOW, RED, GREY - from edge profile
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model MarketCandle {
  id        String   @id @default(cuid())
  asset     String   // EUR/USD, GBP/USD, etc.
  timeframe String   // M1, M5, M15, M30, H1, H4, D1
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())

  @@unique([asset, timeframe, timestamp])
  @@index([asset, timeframe, timestamp])
}

model SetupStats {
  id            String   @id @default(cuid())
  patternType   String   // breakout, liquidity_sweep, engulfing, fakeout, reversal, trend_continuation, momentum_shift
  asset         String?  // null = all assets
  session       String?  // null = all sessions; Asia, London, New York, Overlap
  timeframe     String?  // null = all timeframes
  totalSignals  Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  draws         Int      @default(0)
  noOperarCount Int      @default(0)
  winRate       Float    @default(0)
  avgConfidence Float    @default(0)
  avgSetupScore Float    @default(0)
  // === BAYESIAN STATS (Phase 4) ===
  bayesianWinRate        Float    @default(0)  // Bayesian adjusted WR with prior
  confidenceIntervalLower Float   @default(0)  // 95% CI lower bound
  confidenceIntervalUpper Float   @default(0)  // 95% CI upper bound
  pValue                 Float    @default(1)  // P-value vs H0: WR=50%
  sampleVariance         Float    @default(0)  // Variance of outcomes
  // === EXPECTANCY (Phase 4) ===
  avgExpectancy          Float    @default(0)  // Average EV per trade
  avgRiskReward          Float    @default(0)  // Average risk/reward ratio
  // === QUALITY (Phase 4) ===
  avgQualityScore        Float    @default(0)  // Average quality score
  lastUpdated   DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([patternType, asset, session, timeframe])
}

model Alert {
  id          String   @id @default(cuid())
  type        String
  message     String
  severity    String   @default("warning") // info, warning, critical
  isActive    Boolean  @default(true)
  dismissedAt DateTime?
  signalId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// === EXECUTION ENGINE MODELS (Phase 8) ===

model Trade {
  id                String   @id @default(cuid())
  signalId          String?  // Link to the originating signal (null for manual trades)
  asset             String   // BTC/USD, ETH/USD
  direction         String   // BUY, SELL
  // === Order Details ===
  orderType         String   @default("MARKET") // MARKET, LIMIT
  orderSide         String   // Buy, Sell (broker side)
  quantity          Float    // Position size in base currency
  leverage          Float    @default(1) // Leverage multiplier
  // === Prices ===
  signalPrice       Float    // Price at signal generation time
  entryPrice        Float?   // Actual fill price
  exitPrice         Float?   // Actual exit fill price
  stopLoss          Float?   // Stop loss price
  takeProfit        Float?   // Take profit price
  // === Execution Metadata ===
  brokerOrderId     String?  // Broker's order ID
  brokerExecId      String?  // Broker's execution ID
  slippage          Float?   // Difference between signal and fill price
  commission        Float    @default(0) // Trading fee paid
  fillTime          DateTime? // When order was filled
  // === P&L ===
  realizedPnl       Float?   // Profit/Loss in quote currency
  realizedPnlPct    Float?   // Profit/Loss as percentage
  // === Status ===
  status            String   @default("PENDING") // PENDING, OPEN, CLOSING, CLOSED, CANCELLED, REJECTED, ERROR
  rejectReason      String?  // Why the order was rejected
  // === Risk Management ===
  riskPercent       Float?   // % of account risked
  positionValueUsd  Float?   // Total position value in USD
  // === Audit ===
  executionMode     String   @default("PAPER") // PAPER, LIVE
  journalNotes      String?  // Manual notes
  metadataJson      String?  // JSON: additional execution metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  closedAt          DateTime?
}

model Position {
  id                String   @id @default(cuid())
  tradeId           String?  // Link to the opening trade
  asset             String   // BTC/USD, ETH/USD
  direction         String   // BUY, SELL
  quantity          Float    // Position size
  leverage          Float    @default(1)
  entryPrice        Float    // Average entry price
  stopLoss          Float?   // Current stop loss
  takeProfit        Float?   // Current take profit
  // === Mark-to-Market ===
  currentPrice      Float?   // Latest mark price
  unrealizedPnl     Float?   // Unrealized P&L
  unrealizedPnlPct  Float?   // Unrealized P&L %
  // === Broker ===
  brokerPositionId  String?  // Broker's position ID
  // === Status ===
  status            String   @default("OPEN") // OPEN, CLOSING, CLOSED, LIQUIDATED
  // === Risk Tracking ===
  maxFavorable      Float?   // Maximum favorable excursion
  maxAdverse        Float?   // Maximum adverse excursion
  // === Audit ===
  executionMode     String   @default("PAPER") // PAPER, LIVE
  metadataJson      String?  // JSON: additional position metadata
  openedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt
  closedAt          DateTime?
}

model Account {
  id                String   @id @default(cuid())
  broker            String   @default("BYBIT") // BYBIT, BINANCE, PAPER
  accountId         String?  // Broker account ID
  // === Balance ===
  balance           Float    @default(0) // Available balance
  equity            Float    @default(0) // Balance + unrealized P&L
  unrealizedPnl     Float    @default(0) // Total unrealized P&L
  // === Risk Metrics ===
  dailyPnl          Float    @default(0) // Today's realized + unrealized P&L
  dailyTrades       Int      @default(0) // Today's trade count
  maxDrawdown       Float    @default(0) // Maximum drawdown from peak equity
  peakEquity        Float    @default(0) // Highest equity reached
  // === Configuration ===
  isLive            Boolean  @default(false) // true = real money, false = paper
  riskPerTrade      Float    @default(1) // % of account to risk per trade
  maxDailyLoss      Float    @default(3) // Max daily loss as % of balance
  maxOpenPositions  Int      @default(3) // Max concurrent open positions
  maxDrawdownPct    Float    @default(10) // Max drawdown % before auto-stop
  // === API Keys (encrypted in production) ===
  apiKey            String?  // Broker API key
  apiSecret         String?  // Broker API secret (should be env var in prod)
  // === Status ===
  isActive          Boolean  @default(true) // Account is active for trading
  isCircuitBreaker  Boolean  @default(false) // Circuit breaker triggered
  circuitBreakerReason String? // Why circuit breaker triggered
  lastSyncAt        DateTime? // Last balance sync with broker
  // === Audit ===
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// === NEW STRATEGY MODELS (v8) ===

model StrategyPosition {
  id                String   @id @default(cuid())
  strategy          String   // funding_arb, grid_trading, mean_reversion, orderflow
  asset             String   // BTC/USD, ETH/USD
  direction         String?  // HIGHER, LOWER, SHORT_PERP_LONG_SPOT, LONG_PERP_SHORT_SPOT, null for grid
  // === Position Details ===
  entryPrice        Float?
  currentPrice      Float?
  stopLoss          Float?
  takeProfit        Float?
  quantity          Float    @default(0)
  leverage          Float    @default(1)
  // === P&L ===
  unrealizedPnl     Float    @default(0)
  realizedPnl       Float    @default(0)
  totalFundingCollected Float @default(0) // For funding arb
  totalFills        Int      @default(0)  // For grid trading
  // === Strategy-specific metadata ===
  metadataJson      String?  // JSON: strategy-specific data (grid levels, BB touch, etc.)
  // === Status ===
  status            String   @default("OPEN") // OPEN, CLOSING, CLOSED, STOPPED
  closeReason       String?
  // === Risk ===
  maxFavorable      Float    @default(0)
  maxAdverse        Float    @default(0)
  // === Audit ===
  executionMode     String   @default("PAPER") // PAPER, LIVE
  openedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt
  closedAt          DateTime?

  @@index([strategy, status])
  @@index([asset, strategy])
}

model StrategyStats {
  id                String   @id @default(cuid())
  strategy          String   // funding_arb, grid_trading, mean_reversion, orderflow
  asset             String?  // null = all assets
  // === Performance ===
  totalTrades       Int      @default(0)
  totalWins         Int      @default(0)
  totalLosses       Int      @default(0)
  winRate           Float    @default(0)
  totalPnl          Float    @default(0)
  avgPnlPerTrade    Float    @default(0)
  profitFactor      Float    @default(0)
  maxDrawdown       Float    @default(0)
  sharpeRatio       Float    @default(0)
  // === Strategy-specific ===
  totalFundingCollected Float @default(0) // funding arb
  totalGridFills    Int      @default(0)  // grid trading
  avgHoldingPeriodHours Float @default(0)
  // === Period ===
  period            String   @default("ALL") // ALL, DAILY, WEEKLY, MONTHLY
  // === Audit ===
  lastUpdated       DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([strategy, asset, period])
}
