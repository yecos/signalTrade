# === DATABASE ===
# Local SQLite (development fallback)
DATABASE_URL=file:./db/custom.db

# Turso (production - remote libSQL)
# Get these from: https://turso.tech/app
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.so
# TURSO_AUTH_TOKEN=eyJhbGciOiJFZHV...

# === MARKET DATA APIs ===
# Binance WebSocket (Crypto - free, real-time)
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_API_SECRET=your_binance_api_secret

# Twelve Data (Forex - free tier: 800 requests/day)
# TWELVEDATA_API_KEY=your_twelvedata_api_key

# Finnhub (Forex/Stocks - free tier: 60 calls/min)
# FINNHUB_API_KEY=your_finnhub_api_key

# === AUTH (Supabase - future) ===
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# === AI (optional - NOT used yet, dataset priority first) ===
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434
